    {
      "parameters": {
        "jsCode": "// TODO: Replace these placeholders after import.\nconst clientId = 'Q285bFM0VUJLdlJHTk82aW5YcVE6MTpjaQ';\nconst clientSecret = 'ZAApmo-Z6kzX-fYYyyWjCffziJfRNP8yVURxEdIgyYmKoea3nH';\nconst redirectUri = 'https://tarek1207.app.n8n.cloud/webhook/x-oauth-callback';\n\nif (\n  clientId === 'YOUR_X_CLIENT_ID' ||\n  clientSecret === 'YOUR_X_CLIENT_SECRET' ||\n  redirectUri === 'YOUR_N8N_CALLBACK_URL'\n) {\n  throw new Error('Replace YOUR_X_CLIENT_ID, YOUR_X_CLIENT_SECRET, and YOUR_N8N_CALLBACK_URL before activating this workflow.');\n}\n\nconst auth = Buffer.from(`${clientId}:${clientSecret}`).toString('base64');\n\nreturn [{\n  json: {\n    ...$json,\n    redirect_uri: redirectUri,\n    authorization: `Basic ${auth}`,\n  },\n}];"
