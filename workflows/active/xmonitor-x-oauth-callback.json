    {
      "parameters": {
        "jsCode": "const query = $json.query || $json.queryParameters || {};\nconst code = query.code || $json.code;\nconst state = query.state || $json.state;\nconst error = query.error || $json.error;\nconst errorDescription = query.error_description || $json.error_description || '';\n\nif (error) {\n  return [{\n    json: {\n      callback_ok: false,\n      response_text: `X authorization failed: ${error}${errorDescription ? ` - ${errorDescription}` : ''}`,\n    },\n  }];\n}\n\nif (!code || !state) {\n  return [{\n    json: {\n      callback_ok: false,\n      response_text: 'Invalid X authorization callback. Missing code or state.',\n    },\n  }];\n}\n\nreturn [{\n  json: {\n    callback_ok: true,\n    code,\n    state,\n  },\n}];"
      },
