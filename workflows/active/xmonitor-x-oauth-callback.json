    {
      "parameters": {
        "jsCode": "const session = $json || {};\nconst code = $('Parse Callback').first().json.code;\nconst state = $('Parse Callback').first().json.state;\n\nif (!session.state) {\n  return [{\n    json: {\n      session_ok: false,\n      response_text: 'X authentication session was not found. Please return to Telegram and send /auth_x again.',\n    },\n  }];\n}\n\nconst used = session.used === true || session.used === 'true';\nif (used) {\n  return [{\n    json: {\n      session_ok: false,\n      response_text: 'This X authentication link has already been used. Please return to Telegram and send /auth_x again.',\n    },\n  }];\n}\n\nconst expiresAt = new Date(session.expires_at).getTime();\nif (!expiresAt || Number.isNaN(expiresAt) || expiresAt < Date.now()) {\n  return [{\n    json: {\n      session_ok: false,\n      response_text: 'This X authentication link has expired. Please return to Telegram and send /auth_x again.',\n    },\n  }];\n}\n\nreturn [{\n  json: {\n    session_ok: true,\n    code,\n    state,\n    telegram_chat_id: String(session.telegram_chat_id),\n    code_verifier: session.code_verifier,\n    session_expires_at: session.expires_at,\n  },\n}];"
      },
