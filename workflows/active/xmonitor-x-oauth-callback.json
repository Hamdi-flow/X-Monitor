    {
      "parameters": {
        "jsCode": "const tokens = $('Exchange Code For Tokens').first().json;\nconst session = $('Validate Auth Session').first().json;\nconst user = $json.data || {};\n\nif (!tokens.access_token) {\n  throw new Error('X token exchange did not return an access_token.');\n}\n\nif (!user.id) {\n  throw new Error('X /2/users/me did not return a user id.');\n}\n\nconst expiresInSeconds = Number(tokens.expires_in || 0);\nconst expiresAt = expiresInSeconds > 0\n  ? new Date(Date.now() + expiresInSeconds * 1000).toISOString()\n  : null;\n\nreturn [{\n  json: {\n    telegram_chat_id: session.telegram_chat_id,\n    state: session.state,\n    code_verifier: session.code_verifier,\n    session_expires_at: session.session_expires_at,\n    x_user_id: String(user.id),\n    x_username: user.username || '',\n    access_token: tokens.access_token,\n    refresh_token: tokens.refresh_token || '',\n    expires_at: expiresAt,\n    scope: tokens.scope || '',\n    updated_at: new Date().toISOString(),\n  },\n}];"
      },
